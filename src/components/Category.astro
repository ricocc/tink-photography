---
// https://lefruitstudio.fr/
import ArrowIcon from "./ArrowIcon.astro";
import { Image } from "astro:assets";
import Sunset from "../assets/category/sunset.jpg";
import Nature from "../assets/category/nature.jpg";
import City from "../assets/category/city.jpg";
import Moment from "../assets/category/moment.jpg";
import Altay from "../assets/category/altay.jpg";
---

<section class="category">
  <div class="category-container gsap-category__wrapper">
    <div class="category-card-wrap category-grid swiper mySwiper">
        <h2 class="heading-02 category-title">
          主题分类
        </h2>
      <div class="category-grid__inner swiper-wrapper">

        <div class="category-card swiper-slide">
          <a href="/collection/sunset" class="picture-wrapper">
            <picture class="picture-inner">
              <Image
                src={Sunset}
                alt="Sunset"
                class="category-card__img picture__img"
              />
            </picture>
          </a>
          <a href="/collection/sunset" class="category-card__title link-solid" data-splitting>
            <div class="category-card__icon">
              <img src="/icon/arrow-right.svg" alt="" class="category-card__arrow">
            </div>
            日落
            <div class="upper-number" data-splitting>
              (18)
            </div>
          </a>
        </div>

        <div class="category-card swiper-slide offset-1">
          <a href="/collection/nature" class="picture-wrapper">
            <picture class="picture-inner">
              <Image
              src={Nature}
              alt="Nature"
              class="category-card__img picture__img"
            />
            </picture>
          </a>
          <a href="/collection/nature" class="category-card__title link-solid" data-splitting>
            <div class="category-card__icon">
              <img src="/icon/arrow-right.svg" alt="" class="category-card__arrow">
            </div>
            自然
            <div class="upper-number" data-splitting>
              (19)
            </div>
          </a>
        </div>
        <div class="category-card swiper-slide offset-1">
          <a href="/collection/city" class="picture-wrapper">
            <picture class="picture-inner">
              <Image
              src={City}
              alt="City"
              class="category-card__img picture__img"
            />
            </picture>
          </a>
          <a href="/collection/city" class="category-card__title link-solid" data-splitting>
            <div class="category-card__icon">
              <img src="/icon/arrow-right.svg" alt="" class="category-card__arrow">
            </div>城市
            <div class="upper-number" data-splitting>
              (24)
            </div>
          </a>
        </div>
        <div class="category-card swiper-slide offset-1">
          <a href="/collection/moment" class="picture-wrapper">
            <picture class="picture-inner">
              <Image
              src={Moment}
              alt="Moment"
              class="category-card__img picture__img"
            />
            </picture>
          </a>
          <a href="/collection/moment" class="category-card__title link-solid" data-splitting>
            <div class="category-card__icon">
              <img src="/icon/arrow-right.svg" alt="" class="category-card__arrow">
            </div>
            瞬间
            <div class="upper-number" data-splitting>
              (12)
            </div></a>
        </div>

        <div class="category-card swiper-slide offset-1">
          <a href="/posts/altay" class="picture-wrapper">
            <picture class="picture-inner">
              <Image
              src={Altay}
              alt="Altay"
              class="category-card__img picture__img"
            />
           </picture>
          </a>
          <a href="/posts/altay" class="category-card__title link-solid"  data-splitting>
              <div class="category-card__icon">
                <img src="/icon/arrow-right.svg" alt="" class="category-card__arrow">
              </div>
              阿勒泰
            <div class="upper-number" data-splitting>
              (17)
            </div>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>


<script>
  import Swiper from "swiper/bundle";
  import "swiper/css/bundle";
  var swiper = new Swiper(".mySwiper", {
    autoplay: false,
    // freeMode: true,
    slidesPerView: "auto",
    // breakpoints: {
    //   768: {
    //     //当屏幕宽度大于等于768
    //     slidesPerView: 2.5,
    //   },
    //   1024: {
    //     //当屏幕宽度大于等于1024
    //     slidesPerView: 3.5,
    //   }
    // }
  });
</script>

<style lang="scss">
  .upper-number{
    font-size: 0.53333333em;
    font-weight: 600;
    font-family: var(--font-2);
    vertical-align: sub;
    align-self: self-start;
    padding-top:0.2em;
    padding-left: 0.2em;
  }
  .category{
    padding:100px 0 0;
  }
  .category-container {
    width: 100%;
  }
  .category-grid {
    padding: 0 var(--pad-inner);
  }
  .swiper {
    width: 100%;
    height: 100%;
  }

  .swiper-slide img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .picture-wrapper{
    height: 17.5em;
    @media (min-width: 767px) {
      height: 18em;
    }
    @media (min-width: 1200px) {
      height: 18.5em;
    }
    @media (min-width: 1400px) {
      height: 22.5em;
    }
  }
  .category-card {
    &__title {
      display: inline-flex;
      align-items: center;
      justify-content: flex-start;
      color: var(--color-50);
      font-size: 1.5rem;
      line-height: 1.3;
      text-align: left;
      margin-top: 10px;
      font-weight: bold;
      overflow:hidden;
      transition: all 1s ease-in-out;
      @media (min-width: 767px) {
        font-size: 30px;
      }
      &:hover {
        text-decoration: none;
      }
    }
  }
  .category-card {
    width: 60vw;
    padding: 0 10px;
    &:nth-child(5n + 1) {
        width: 64vw;
        padding-left: 0;
      .category-card__img {
        aspect-ratio: 4 / 3;
      }
    }
    &:nth-child(5n + 2) {
        margin-top: 16.875vw;
        width: 50vw;
      .category-card__img {
        aspect-ratio: 4 / 5;
      }
    }
    &:nth-child(5n + 3) {
        margin-top: 5.375vw;
        width: 75vw;
      .category-card__img {
        aspect-ratio: 3 / 2;
      }
    }
    &:nth-child(5n + 4) {
        margin-top:15vw;
        width:50vw;
      .category-card__img {
        aspect-ratio: 4 / 5;
      }
    }
    &:nth-child(5n + 5) {
        margin-top: 8.0625vw;
        width: 64vw;
      .category-card__img {
        aspect-ratio: 1 / 1;
      }
    }
    &:last-child{
        padding-right: 0;
    }
  }
  .category-card {
    @media (min-width: 576px) {
      &:nth-child(5n + 1) {
        width: 40vw;
      }
      &:nth-child(5n + 2) {
        width: 30vw;
      }
      &:nth-child(5n + 3) {
        width: 40vw;
      }
      &:nth-child(5n + 4) {
        width: 32vw;
      }
      &:nth-child(5n + 5) {
        width: 42vw;
      }
    }
    @media (min-width: 1220px) {
      padding: 0 20px;
      &:nth-child(5n + 1) {
        width: 23.6979vw;
      }
      &:nth-child(5n + 2) {
        margin-top: 5.625vw;
        aspect-ratio: 4 / 5;
        width: 20.4688vw;
      }
      &:nth-child(5n + 3) {
        margin-top: 2rem;
        aspect-ratio: 3 / 2;
        width: 26.6979vw;
      }
      &:nth-child(5n + 4) {
        margin-top: 6.25vw;
        aspect-ratio: 4 / 5;
        width: 20.4688vw;
      }
      &:nth-child(5n + 5) {
        margin-top: 3.75vw;
        aspect-ratio: 1 / 1;
        width: 22.3125vw;
      }
    }
    @media (min-width: 1400px) {
      &:nth-child(5n + 1) {
        width: 23.6979vw;
      }
      &:nth-child(5n + 2) {
        margin-top: 5.625vw;
        aspect-ratio: 4 / 5;
      }
      &:nth-child(5n + 3) {
        margin-top: 2rem;
        aspect-ratio: 3 / 2;
        width: 23.6979vw;
      }
      &:nth-child(5n + 4) {
        margin-top: 6.25vw;
        aspect-ratio: 4 / 5;

      }
      &:nth-child(5n + 5) {
        margin-top: 3.75vw;
        aspect-ratio: 1 / 1;
        width: 20.3125vw;
      }
    }
  }


  @media (min-width: 767px) {
    .category-card__icon{
      height:32px;
      width:0px;
      transition: all 0.5s ease-in-out;
      will-change: transform;
      overflow: hidden;
      transform: translateX(-200%);
    }
    .category-card__icon img, .category-card__icon svg{
      width: 28px;
      height:28px;
      transition: all 1s ease-in-out;
    }
    .category-card__title:hover  .category-card__icon{
      width:36px;
      transform: translateX(0%);
    }
    .category-card__title:hover  .category-card__icon img{
    }
  }
</style>
