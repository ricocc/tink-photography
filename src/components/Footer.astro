---
import { siteConfig } from "../config/site";
const year = new Date().getFullYear();
const designLink = siteConfig.socials.find((item) => item.id === "design");
if (!designLink?.href) throw new Error("The design social link must define an href.");
---
<footer id="footer">
  <section class="container footer"><div class="row">
    <div class="col-4 col-lg-1"><div class="footer-title"><a href="/" class="footer-logo">{siteConfig.shortName}</a></div></div>
    <div class="d-none d-lg-block col-3 offset-lg-5 offset-xl-6 col-lg-1"></div>
    <div class="nav-primary offset-1 offset-lg-0 col-7 col-lg-3 col-xl-2 text-right"> <a href="/blog" target="_blank" rel="noopener noreferrer">博客</a></div>
    <a href="#top" class="d-none d-md-block col-3 col-lg-2 site-header__aside text-right backtotop">回到顶部 ↑</a>
  </div></section>
</footer>
<style>.footer{font-size:.875rem;margin:120px auto 0;height:60px;display:block}.footer-title{font-weight:bold}</style>
