---
import RootLayout from "../layouts/RootLayout.astro";

---

<RootLayout
  page="404"
  title="404 | Tink",
  description="方圆十里无人烟",
  keywords="404 Page"
>
  <div id="nofound">
    <div class="nofound postion-relative">
      <div class="container">
          <div class="header text-center">
              <div class="title  ">
                方圆十里无人烟
              </div>
          </div>
          <div class="body  text-center">
            <div class="nofound-svg">
              <svg width="689" height="174" viewBox="0 0 689 174" fill="var(--color-50)" xmlns="http://www.w3.org/2000/svg">
