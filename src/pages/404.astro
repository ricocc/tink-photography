              </svg>
            </div>
          </div>
          <div class="action text-center">
            <a href="/" class="link link-underlined">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="var(--color-100)" xmlns="http://www.w3.org/2000/svg">
                <path d="M0.99961 8.00051L14.9996 8.00051V10.0005L0.99961 10.0005L0.99961 8.00051Z"/>
                <path d="M9.99961 1.92551L17.0707 8.99658L15.6565 10.4108L8.5854 3.33973L9.99961 1.92551Z"/>
