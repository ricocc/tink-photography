            </a>
          </div>
      </div>
    </div>
  </div>
</RootLayout>
<style>
.nofound{
  width: 100%;
  margin:0 auto;
  text-align:center;
  box-sizing:border-box;
  min-height: calc( 100vh - 180px);
}
.nofound .container{
  text-align: center;
  margin:0 auto;
}
.header{
  padding-top: 160px;
  padding-bottom:60px;
}
.header .title{
  font-weight: 300;
  font-size: 20px;
  letter-spacing: 4px;
  color: var(--color-300);
}
.body{
  margin-top:160px;
  position: relative;
}
.action{
  margin-top: 120px;
}
.action .link{
  font-size: 24px;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: var(--color-50);
}
.action .link svg{
  margin-right:8px;
  width: 1em;
}
.nofound-svg{
  position: relative;
}
.nofound-svg svg{
  max-width: 80%;
  height: auto;
}
.nofound-pic{
  position: absolute;
  left:0;
  right:0;
  margin:0 auto;
  max-width: 200px;
  width:50%;
  top:-85%;
}
@media (max-width: 767px) {
  .header{
    padding-top: 20vh;
    padding-bottom:60px;
  }
  .header .title{
    font-size: 20px;
  }
  .body{
    margin-top:15vh;

  }
  .nofound-pic{
    width:35vw;
    top:-155%;
  }
  .nofound-svg svg{
    max-width: 90%;
  }
  .footer{

  }
}
</style>

